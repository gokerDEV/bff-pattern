{
  "name": "bff-pattern",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "codegen": "orval",
    "arch:check": "depcruise --config .dependency-cruiser.cjs src proxy.ts auth.ts",
